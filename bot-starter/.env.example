# ─── Required: subscription gate ──────────────────────────────────────────
# Get this at https://scgalpha.com after subscribing.
SCG_API_KEY=mem_your_membership_id_here

# ─── Run mode ─────────────────────────────────────────────────────────────
# Start with 1 (dry). Flip to 0 only after stress-testing for 24h+.
SCG_DRY_RUN=1

# ─── Position sizing ──────────────────────────────────────────────────────
# Start TINY when going live ($5-10 per trade).
SCG_BUY_SIZE_SOL=0.05
SCG_MAX_CONCURRENT=3

# ─── Polling ──────────────────────────────────────────────────────────────
SCG_ALERT_POLL_SECS=5
SCG_PRICE_POLL_SECS=5
SCG_SELL_COOLDOWN=60

# ─── Wallet (DEDICATED bot wallet — never your main!) ─────────────────────
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# ─── Jupiter Ultra (free tier at https://portal.jup.ag/) ──────────────────
JUP_API_KEY=

# ─── RPC (Helius free tier at https://helius.dev/) ────────────────────────
HELIUS_API_KEY=

# ─── Optional Telegram alerts ─────────────────────────────────────────────
# Create a bot via @BotFather, add it to a private channel, get chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Optional Jupiter referral (earn fees on swaps) ───────────────────────
SCG_REFERRAL_ACCOUNT=
SCG_REFERRAL_FEE_BPS=0
